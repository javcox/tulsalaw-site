---
import CtaPanel from '../../components/CtaPanel.astro';
import PracticeCard from '../../components/PracticeCard.astro';
import { featuredServices, getServiceUrl, services } from '../../data/site';
import Layout from '../../layouts/Layout.astro';

const primarySlugs = new Set(featuredServices.map((service) => service.slug));
const orderedServices = [
	...featuredServices,
	...services.filter((service) => !primarySlugs.has(service.slug)),
];

const laneGroups = [
	{
		title: 'Personal Injury Review',
		copy: 'Start here when the first question is whether an injury claim is worth pursuing.',
		links: [
			'personal-injury',
			'tulsa-car-accident-lawyer',
			'tulsa-truck-accident-lawyer',
			'tulsa-motorcycle-accident-lawyer',
			'tulsa-pedestrian-accident-lawyer',
			'tulsa-wrongful-death-lawyer',
			'tulsa-slip-and-fall-lawyer',
		],
	},
	{
		title: 'Legal Guidance',
		copy: 'Start here when you need attorney judgment before deciding what to sign, file, or do next.',
		links: ['legal-guidance', 'family-law', 'business-law'],
	},
	{
		title: 'Estate Planning',
		copy: 'Start here for wills, trusts, powers of attorney, and guardianship-related planning.',
		links: ['estate-planning', 'wills-and-trusts', 'power-of-attorney', 'guardianship'],
	},
	{
		title: 'More Practice Areas',
		copy: 'Use this card for uncontested divorce, LLC formation, contract work, and the rest of the service map.',
		links: ['uncontested-divorce', 'llc-formation', 'contract-drafting-review'],
	},
];
---

<Layout
	title="Practice Areas | Tulsa Law"
	description="Explore Tulsa Law practice areas, including personal injury, legal guidance, estate planning, powers of attorney, family-law matters, LLC formation, and contracts."
	path="/practice-areas/"
>
	<section class="page-hero">
		<div class="shell">
			<div class="hero-card">
				<div class="breadcrumbs">
					<a href="/">Home</a>
					<span>/</span>
					<span>Practice Areas</span>
				</div>
				<p class="eyebrow">Practice Areas</p>
				<h1 class="page-title">Explore the firm&apos;s primary practice areas.</h1>
				<p class="lead">
					This page is the full service map for the firm&apos;s injury review, planning, family,
					and business work. The homepage stays narrower on purpose so the first choice feels
					clearer and less crowded.
				</p>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="shell lane-grid">
			{laneGroups.map((group) => (
				<div class="lane-card">
					<div>
						<p class="section-label">{group.title}</p>
						<h2>{group.title}</h2>
						<p>{group.copy}</p>
						<div class="chips">
							{group.links.map((slug) => {
								const service = services.find((entry) => entry.slug === slug);
								return service ? <a class="chip" href={getServiceUrl(service.slug)}>{service.name}</a> : null;
							})}
						</div>
					</div>
				</div>
			))}
		</div>
	</section>

	<section class="section-xl">
		<div class="shell service-grid">
			{orderedServices.map((service) => <PracticeCard service={service} />)}
		</div>
	</section>

	<CtaPanel
		title="Need the shorter, document-focused route instead?"
		copy="Use Simple Services when the matter is mostly document-driven and you want the faster path before moving into consultation."
		href="/oklahoma-legal-forms/"
	/>
</Layout>
