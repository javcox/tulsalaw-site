---
import CtaPanel from '../../components/CtaPanel.astro';
import PracticeCard from '../../components/PracticeCard.astro';
import { services } from '../../data/site';
import Layout from '../../layouts/Layout.astro';
---

<Layout
	title="Practice Areas | Tulsa Law"
	description="Explore Tulsa Law practice areas, including estate planning, personal injury, wills and trusts, powers of attorney, guardianship planning, family-law matters, LLC formation, and contracts."
	path="/practice-areas/"
>
	<section class="page-hero">
		<div class="shell">
			<div class="hero-card">
				<div class="breadcrumbs">
					<a href="/">Home</a>
					<span>/</span>
					<span>Practice Areas</span>
				</div>
				<p class="eyebrow">Practice Areas</p>
				<h1 class="page-title">Explore the firm's primary practice areas.</h1>
				<p class="lead">
					These pages cover the firm's primary planning, injury, family, and business services.
					Start with the area that best matches your situation, or contact the office if you want
					help choosing the right next step.
				</p>
			</div>
		</div>
	</section>

	<section class="section-xl">
		<div class="shell service-grid">
			{services.map((service) => <PracticeCard service={service} />)}
		</div>
	</section>

	<CtaPanel
		title="Need help choosing the right matter type?"
		copy="Use the contact page if you would like help identifying the service that best fits your matter before you move forward."
	/>
</Layout>
