---
import IntakeExpectationsSection from '../components/IntakeExpectationsSection.astro';
import IntakePathPanel from '../components/IntakePathPanel.astro';
import { featuredServices, firm, getServiceUrl } from '../data/site';
import Layout from '../layouts/Layout.astro';

const schemas = [
	{
		'@context': 'https://schema.org',
		'@type': 'ContactPage',
		name: 'Contact Tulsa Law',
		url: `${firm.url}/contact/`,
	},
];
---

<Layout
	title="Contact Tulsa Law | Consultation Requests"
	description="Email or use the guided intake path to request a consultation with Tulsa Law for Oklahoma estate planning, personal injury, family-law, and business-document matters."
	path="/contact/"
	schemas={schemas}
>
	<section class="page-hero">
		<div class="shell page-frame">
			<div class="hero-card">
				<div class="breadcrumbs">
					<a href="/">Home</a>
					<span>/</span>
					<span>Contact</span>
				</div>
				<p class="eyebrow">Contact</p>
				<h1 class="page-title">Choose the fastest intake path for your matter.</h1>
				<p class="lead">
					New matters are screened for fit, urgency, conflicts, and attorney availability. The
					fastest path is the guided intake form on this site, with email still available if you
					need to explain something before starting. Most requests are reviewed within 1 business
					day when submitted on a business day.
				</p>
			</div>

			<div class="hero-aside">
				<div class="panel">
					<p class="mini-kicker">Tulsa office</p>
					<h2 class="mini-title">Serving Tulsa, Bixby, Broken Arrow, and Oklahoma from Tulsa.</h2>
					<p class="mini-copy">{firm.fullAddress}</p>
					<div class="chips">
						{featuredServices.map((service) => <span class="chip">{service.name}</span>)}
					</div>
				</div>
				<IntakePathPanel />
			</div>
		</div>
	</section>

	<section class="section-xl">
		<div class="shell contact-grid">
			<div class="contact-card">
				<p class="section-label">Email</p>
				<strong>{firm.email}</strong>
				<p>Best when you want to explain the matter, timing, and what documents already exist.</p>
				<div class="stack-actions">
					<a
						class="button button-primary"
						href={firm.emailHref}
						data-track="generate_lead"
						data-track-label="contact-email"
					>
						Email the firm
					</a>
				</div>
			</div>

			<div class="contact-card">
				<p class="section-label">Guided intake form</p>
				<strong>Structured consultation request</strong>
				<p>
					Use the guided intake if you want the matter screened for fit, timing, and next-step routing.
				</p>
				<div class="stack-actions">
					<a
						class="button button-primary"
						href={firm.consultationUrl}
						data-track="generate_lead"
						data-track-label="contact-secure-form"
					>
						Start Intake
					</a>
				</div>
			</div>

			<div class="contact-card">
				<p class="section-label">What to send</p>
				<ul class="info-list">
					<li>Your matter type and what result you are trying to achieve</li>
					<li>Any deadline, hearing date, filing pressure, or urgent timing</li>
					<li>County, location, and whether the matter is already active</li>
					<li>The best email address and phone number for follow-up</li>
				</ul>
			</div>
		</div>
	</section>

	<IntakeExpectationsSection />

	<section class="section">
		<div class="shell">
			<div class="section-head">
				<div>
					<p class="eyebrow">Start with the right page</p>
					<h2 class="section-title">If you already know the matter type, go straight there</h2>
				</div>
			</div>

			<div class="grid-3">
				{featuredServices.map((service) => (
					<div class="card">
						<h3>{service.name}</h3>
						<p>{service.summary}</p>
						<div class="stack-actions">
							<a class="button button-ghost" href={getServiceUrl(service.slug)}>
								Open {service.name}
							</a>
						</div>
					</div>
				))}
			</div>
		</div>
	</section>
</Layout>
