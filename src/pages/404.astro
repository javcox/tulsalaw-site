---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Page Not Found | Tulsa Law" description="The page you were looking for is not here. Start from the Tulsa Law homepage or the practice-area index." path="/404/">
	<section class="section-xl">
		<div class="shell">
			<div class="hero-card">
				<p class="eyebrow">404</p>
				<h1 class="page-title">That page is gone, but the intake path is still open.</h1>
				<p class="lead">
					Start from the homepage, browse the practice areas, or go straight to contact if you
					already know what you need.
				</p>
				<div class="hero-actions">
					<a class="button button-primary" href="/">Back to home</a>
					<a class="button button-secondary" href="/practice-areas/">Browse practice areas</a>
				</div>
			</div>
		</div>
	</section>
</Layout>
