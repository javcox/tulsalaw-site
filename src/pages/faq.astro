---
import CtaPanel from '../components/CtaPanel.astro';
import { firm, homepageFAQs } from '../data/site';
import Layout from '../layouts/Layout.astro';

const faqItems = [
	...homepageFAQs,
	{
		question: 'Does Tulsa Law only help Tulsa clients?',
		answer:
			'No. The office is in Tulsa, but the firm can review matters from across Oklahoma when they fit the attorney\'s scope and availability.',
	},
	{
		question: 'What if I am not sure which practice area fits my issue?',
		answer:
			'That is common. Start with the page that feels closest to the matter or use the guided intake and choose the lane that feels nearest to the issue.',
	},
	{
		question: 'Can I use Tulsa Law even if I found the main firm site first?',
		answer:
			'Yes. This site is a focused intake and search site. The guided intake here is the cleanest path for getting the matter reviewed for fit and next steps.',
	},
	{
		question: 'What is the fastest way to hear back?',
		answer:
			'The guided intake is the fastest path because it collects the service lane, timing, and fit details the firm needs first. Email is still available if you need to explain something before starting.',
	},
];
---

<Layout
	title="Tulsa Law FAQ | Oklahoma Consultation and Practice Questions"
	description="Answers to common questions about Tulsa Law, consultation requests, practice areas, and how the site works for Oklahoma legal matters."
	path="/faq/"
>
	<section class="page-hero">
		<div class="shell">
			<div class="hero-card">
				<div class="breadcrumbs">
					<a href="/">Home</a>
					<span>/</span>
					<span>FAQ</span>
				</div>
				<p class="eyebrow">FAQ</p>
				<h1 class="page-title">Questions people ask before they decide to reach out.</h1>
				<p class="lead">
					This page is here to reduce friction before you reach out. If the answer depends on the
					facts, timing, or the right legal lane, the next best move is the guided intake or a
					direct email.
				</p>
				<div class="trust-strip" aria-label="FAQ trust indicators">
					<span>Tulsa office</span>
					<span>Attorney-led review</span>
					<span>Guided intake or email</span>
					<span>Most requests reviewed within 1 business day</span>
				</div>
				<p class="mini-copy hero-summary">
					This page works best when you need one clear answer before you choose a lane. Use guided
					intake if the matter needs fact-specific review instead of a general explanation.
				</p>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="shell highlight-band">
			<div class="band">
				<p class="eyebrow">Use FAQ for</p>
				<h2 class="section-title">Quick answers before you decide how to start.</h2>
				<ul class="checklist">
					<li>Understanding whether the site fits the kind of matter you have</li>
					<li>Choosing between Practice Areas, Simple Services, email, or guided intake</li>
					<li>Checking how the consultation-request process works before you begin</li>
				</ul>
			</div>
			<div class="band">
				<p class="eyebrow">Use guided intake instead</p>
				<h2 class="section-title">When the answer depends on the actual facts and timing.</h2>
				<ul class="checklist">
					<li>Personal injury matters that need fit review on liability, treatment, and damages</li>
					<li>Planning, family, business, or document matters that need the right next step</li>
					<li>Questions where the office needs the county, urgency, or current posture first</li>
				</ul>
			</div>
		</div>
	</section>

	<section class="section-xl">
		<div class="shell">
			<div class="faq-list">
				{faqItems.map((item) => (
					<div class="faq-item">
						<details>
							<summary>{item.question}</summary>
							<p>{item.answer}</p>
						</details>
					</div>
				))}
			</div>
		</div>
	</section>

	<CtaPanel
		title="Still deciding whether the matter is a fit?"
		copy={`Use the guided intake or email ${firm.email} and describe the issue in plain language.`}
	/>
</Layout>
