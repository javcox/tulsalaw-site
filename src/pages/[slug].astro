---
import CtaPanel from '../components/CtaPanel.astro';
import { firm, getServiceUrl, services, type Service } from '../data/site';
import Layout from '../layouts/Layout.astro';

export function getStaticPaths() {
	return services.map((service) => ({
		params: { slug: service.slug },
		props: { service },
	}));
}

const { service } = Astro.props as { service: Service };
const moneyPageServices = services.filter((entry) => service.moneyPageLinks?.includes(entry.slug));
const siblingSupportServices = services.filter((entry) => service.siblingSupportLinks?.includes(entry.slug));
const relatedServices = services.filter((entry) => service.related.includes(entry.slug));

const categoryCopy = {
	Guidance: {
		overview:
			'Best for issues that need attorney judgment before anything gets signed, filed, or pushed into the wrong lane.',
		expectation:
			'Most legal-guidance clients want a serious review of the facts, the pressure points, and the smartest next step before they commit more time or money.',
		consultation:
			'For many legal-guidance matters that fit, the next step is the $100 30-minute consultation by email because strategy review, document review, or attorney judgment is needed before a recommendation is made.',
	},
	Planning: {
		overview:
			'Best for documents, authority decisions, and family planning that should be handled before a crisis makes everything harder.',
		expectation:
			'Most planning clients are trying to avoid confusion later. The first question is usually whether the documents match the family, the assets, and the people who may have to act.',
		consultation:
			'For many planning matters that fit, the next step is the $100 30-minute consultation by email so the documents, family structure, and next drafting steps can be reviewed carefully.',
	},
	Family: {
		overview:
			'Best for family matters involving document preparation, filings, agreements, or clearer next steps before tensions rise.',
		expectation:
			'Most family-law clients want to know what is urgent, what can wait, and what paperwork or decisions need attention first.',
		consultation:
			'For many family-law matters that fit, the next step is the $100 30-minute consultation by email so filings, agreements, or next-step strategy can be reviewed carefully.',
	},
	Injury: {
		overview:
			'Best when the real question is whether liability, treatment, insurance, and damages justify moving forward.',
		expectation:
			'Most injury clients want an honest first look at fault, treatment, and whether the claim appears strong enough to justify more time and attention.',
		consultation:
			'Personal injury matters are screened for fit first. The goal of intake is to decide whether liability, treatment, damages, and insurance appear strong enough to justify a deeper review, rather than treating the matter like a standard paid consultation from the start.',
	},
	Business: {
		overview:
			'Best for ownership, agreements, document cleanup, or business decisions that need attention before they become disputes.',
		expectation:
			'Most business clients want to know whether the agreement, structure, or filing is sound enough to move forward without avoidable risk.',
		consultation:
			'For many business matters that fit, the next step is the $100 30-minute consultation by email so contracts, company records, or formation documents can be reviewed carefully.',
	},
} as const;

const currentCategory = categoryCopy[service.category as keyof typeof categoryCopy];

const reviewFocusByCategory = {
	Guidance: [
		'What decision has to be made next, and what gets riskier if it waits',
		'Whether the matter really belongs in family, business, planning, or injury review',
		'Whether a document, consultation, or broader legal strategy is the right next step',
	],
	Planning: [
		'Who needs authority, protection, or clearer instructions before a crisis',
		'Whether the current documents still fit the family, assets, and decision-makers',
		'What should be drafted, updated, or coordinated first so the plan works cleanly later',
	],
	Family: [
		'What is urgent, what can wait, and which filings or agreements matter first',
		'Whether the matter looks document-driven or likely to expand into a broader family issue',
		'What next step is practical without making the situation more adversarial than it needs to be',
	],
	Injury: [
		'Whether liability looks strong enough to justify further review',
		'Whether treatment, damages, and timing support a meaningful claim',
		'Whether insurance or another realistic source of recovery appears available',
	],
	Business: [
		'Whether the agreement, formation work, or cleanup issue is specific enough to review efficiently',
		'What risk sits in the paperwork, ownership structure, or deal terms right now',
		'Whether the matter needs targeted document work or broader legal guidance before moving ahead',
	],
} as const;

const pathGuidanceByCategory = {
	Guidance: {
		title: 'Use a different path if the next step is already obvious.',
		copy:
			'Legal Guidance is best when the issue still needs attorney judgment before it lands in the right bucket. If you already know the matter is mainly planning, injury review, or a short document issue, the narrower path is usually better.',
		chips: [
			{ label: 'Legal Guidance', href: '/legal-guidance/' },
			{ label: 'Practice Areas', href: '/practice-areas/' },
			{ label: 'Simple Services', href: '/oklahoma-legal-forms/' },
		],
		secondaryHref: '/practice-areas/',
		secondaryLabel: 'See Practice Areas',
	},
	Planning: {
		title: 'Use the shorter planning route if the matter is mostly document-focused.',
		copy:
			'These planning pages are often the right place to start, but some clients prefer the shorter Simple Services route when they already know the matter is mostly about documents, updates, or attorney review before drafting.',
		chips: [
			{ label: 'Estate Planning', href: '/estate-planning/' },
			{ label: 'Simple Services', href: '/oklahoma-legal-forms/' },
			{ label: 'Legal Guidance', href: '/legal-guidance/' },
		],
		secondaryHref: '/oklahoma-legal-forms/',
		secondaryLabel: 'Use Simple Services',
	},
	Family: {
		title: 'Use a broader or shorter route depending on how contained the family matter is.',
		copy:
			'Family matters often start in Legal Guidance or Practice Areas. If the issue is mostly an uncontested or document-heavy path, the shorter Simple Services route may save time.',
		chips: [
			{ label: 'Legal Guidance', href: '/legal-guidance/' },
			{ label: 'Practice Areas', href: '/practice-areas/' },
			{ label: 'Simple Services', href: '/oklahoma-legal-forms/' },
		],
		secondaryHref: '/legal-guidance/',
		secondaryLabel: 'Use Legal Guidance',
	},
	Injury: {
		title: 'Stay in injury review when fault, treatment, and damages are the main question.',
		copy:
			'These pages are for injury matters that need an honest fit review first. If the issue also needs broader family, planning, or business judgment, Legal Guidance or the broader practice map may be a better starting point.',
		chips: [
			{ label: 'Personal Injury Review', href: '/personal-injury/' },
			{ label: 'Legal Guidance', href: '/legal-guidance/' },
			{ label: 'Practice Areas', href: '/practice-areas/' },
		],
		secondaryHref: '/personal-injury/',
		secondaryLabel: 'See Injury Review',
	},
	Business: {
		title: 'Use the shorter route for contained document work, or Legal Guidance if the business issue is wider.',
		copy:
			'LLC formation and contract review often fit the shorter Simple Services path. Broader business issues may fit better in Legal Guidance or the wider Practice Areas map.',
		chips: [
			{ label: 'Simple Services', href: '/oklahoma-legal-forms/' },
			{ label: 'Legal Guidance', href: '/legal-guidance/' },
			{ label: 'Practice Areas', href: '/practice-areas/' },
		],
		secondaryHref: '/oklahoma-legal-forms/',
		secondaryLabel: 'Use Simple Services',
	},
} as const;

const currentReviewFocus =
	reviewFocusByCategory[service.category as keyof typeof reviewFocusByCategory] ?? [];
const currentPathGuidance =
	pathGuidanceByCategory[service.category as keyof typeof pathGuidanceByCategory];

const nextStepBullets =
	service.category === 'Injury'
		? [
				'Start with the closest injury page or use the injury review lane.',
				'Send the core facts on liability, treatment, damages, and insurance instead of a long narrative.',
				'The office screens the matter for fit first before discussing deeper review.',
			]
		: [
				'Start with the closest page or use the shorter document route if it fits better.',
				'Send the core facts in about 2 to 4 minutes so the matter lands in the right review lane.',
				'If the matter fits, the next step is often the $100 30-minute consultation by email.',
			];

const mergedRelatedServices = [
	...moneyPageServices,
	...siblingSupportServices,
	...relatedServices,
].filter((entry, index, array) => array.findIndex((candidate) => candidate.slug === entry.slug) === index);

const schemas = [
	{
		'@context': 'https://schema.org',
		'@type': 'LegalService',
		name: service.name,
		url: `${firm.url}/${service.slug}/`,
		description: service.metaDescription,
		keywords: service.searchPhrases,
		provider: {
			'@type': 'Attorney',
			name: firm.legalName,
		},
		areaServed: ['Tulsa', 'Bixby', 'Broken Arrow', 'Oklahoma'],
		serviceType: service.name,
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{
				'@type': 'ListItem',
				position: 1,
				name: 'Home',
				item: firm.url,
			},
			{
				'@type': 'ListItem',
				position: 2,
				name: service.name,
				item: `${firm.url}/${service.slug}/`,
			},
		],
	},
];
---

<Layout
	title={service.metaTitle}
	description={service.metaDescription}
	path={getServiceUrl(service.slug)}
	schemas={schemas}
>
	<section class="page-hero">
		<div class="shell page-frame">
			<div class="hero-card">
				<div class="breadcrumbs">
					<a href="/">Home</a>
					<span>/</span>
					<a href="/practice-areas/">Practice Areas</a>
					<span>/</span>
					<span>{service.name}</span>
				</div>
				<p class="eyebrow">{service.eyebrow}</p>
				<h1 class="page-title">{service.heroTitle}</h1>
				<p class="lead">{service.intro}</p>

				<div class="trust-strip" aria-label="Service page trust indicators">
					<span class="quick-fact">Tulsa office</span>
					<span class="quick-fact">Attorney-led review</span>
					<span class="quick-fact">2 to 4 minute intake</span>
					<span class="quick-fact">Most requests reviewed within 1 business day</span>
				</div>

				<div class="hero-actions">
					<a
						class="button button-primary"
						href={`/start-intake/?service=${service.slug}`}
						data-track="generate_lead"
						data-track-label={`${service.slug}-start-intake`}
					>
						Start Intake
					</a>
					<a class="button button-ghost" href={currentPathGuidance.secondaryHref}>
						{currentPathGuidance.secondaryLabel}
					</a>
				</div>
				<p class="mini-copy hero-summary">
					This usually takes about 2 to 4 minutes, keeps the summary short, and routes the matter
					to the office in the right category for review.
					{` ${currentCategory.consultation}`}
				</p>
			</div>

			<div class="hero-aside">
				<div class="panel">
					<p class="mini-kicker">Best fit</p>
					<ul class="checklist">
						{service.idealFor.map((item) => <li>{item}</li>)}
					</ul>
				</div>
				<div class="panel intake-panel">
					<p class="mini-kicker">What happens next</p>
					<h2 class="mini-title">The review path for this kind of matter.</h2>
					<ol class="intake-steps">
						{nextStepBullets.map((step, index) => (
							<li>
								<strong>{`${index + 1}. ${step}`}</strong>
							</li>
						))}
					</ol>
					<p class="mini-copy">
						Submitting intake does not create an attorney-client relationship, but it does place
						the matter into the office review process.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="section-xl">
		<div class="shell service-overview-grid">
			<div class="panel service-overview-card">
				<p class="eyebrow">What this can include</p>
				<h2 class="section-title">Common needs inside this matter.</h2>
				<ul class="checklist">
					{service.includes.map((item) => <li>{item}</li>)}
				</ul>
			</div>
			<div class="panel service-overview-card">
				<p class="eyebrow">What the office looks for first</p>
				<h2 class="section-title">The questions that shape the first review.</h2>
				<ul class="checklist">
					{currentReviewFocus.map((item) => <li>{item}</li>)}
				</ul>
			</div>
			<div class="panel service-overview-card">
				<p class="eyebrow">{service.category === 'Injury' ? 'Review path' : 'Next step'}</p>
				<h2 class="section-title">
					{service.category === 'Injury'
						? 'Why this matter is screened for fit first.'
						: 'How fitting matters usually move next.'}
				</h2>
				<p class="mini-copy">{currentCategory.consultation}</p>
				<div class="quote service-template-quote">{currentCategory.expectation}</div>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="shell highlight-band">
			<div class="band">
				<p class="eyebrow">What this page helps you decide</p>
				<h2 class="section-title">Whether this is the right fit before you commit more time.</h2>
				<p class="lead" style="margin-top: 0;">{currentCategory.overview}</p>
			</div>
			<div class="band">
				<p class="eyebrow">Use a different path instead</p>
				<h2 class="section-title">{currentPathGuidance.title}</h2>
				<p class="lead" style="margin-top: 0;">{currentPathGuidance.copy}</p>
				<div class="chips">
					{currentPathGuidance.chips.map((chip) => (
						<a class="chip" href={chip.href}>{chip.label}</a>
					))}
					<a class="chip" href={`/start-intake/?service=${service.slug}`}>Start Intake</a>
				</div>
			</div>
		</div>
	</section>

	{service.localSupport && (
		<section class="section">
			<div class="shell">
				<div class="band local-support-band">
					<p class="eyebrow">Tulsa and Nearby</p>
					<h2 class="section-title">{service.localSupport.heading}</h2>
					<p class="lead" style="margin-top: 0;">{service.localSupport.copy}</p>
				</div>
				<ul class="checklist">
					{service.localSupport.bullets.map((item) => <li>{item}</li>)}
				</ul>
			</div>
		</section>
	)}

	<section class="section">
		<div class="shell">
			<div class="section-head">
				<div>
					<p class="eyebrow">FAQ</p>
					<h2 class="section-title">Questions that come up before people reach out</h2>
				</div>
			</div>
			<div class="faq-list">
				{service.faqs.map((item) => (
					<div class="faq-item">
						<details>
							<summary>{item.question}</summary>
							<p>{item.answer}</p>
						</details>
					</div>
				))}
			</div>
		</div>
	</section>

	{mergedRelatedServices.length > 0 && (
		<section class="section">
			<div class="shell split-copy">
				<div class="band">
					<p class="eyebrow">Related pages</p>
					<h2 class="section-title">Pages that may fit the matter more precisely.</h2>
					<div class="related-link-list">
						{mergedRelatedServices.slice(0, 5).map((entry) => (
							<a class="related-link-item" href={getServiceUrl(entry.slug)}>
								<strong>{entry.name}</strong>
								<span>{entry.summary}</span>
							</a>
						))}
					</div>
				</div>
				<div class="band">
					<p class="eyebrow">Wider routes</p>
					<h2 class="section-title">Use the full service map if this page is only close, not exact.</h2>
					<p class="mini-copy">
						The broader routes help when the issue crosses lanes or when you would rather let the
						office place the matter after a shorter summary.
					</p>
					<div class="chips">
						{currentPathGuidance.chips.map((chip) => (
							<a class="chip" href={chip.href}>{chip.label}</a>
						))}
						<a class="chip" href="/contact/">Contact</a>
					</div>
				</div>
			</div>
		</section>
	)}

	<CtaPanel
		title={`Ready to talk about ${service.name.toLowerCase()}?`}
		copy="Use the guided intake to send the matter for fit review and place it in the right review lane."
		href={`/start-intake/?service=${service.slug}`}
		secondaryHref={currentPathGuidance.secondaryHref}
		secondaryLabel={currentPathGuidance.secondaryLabel}
	/>
</Layout>
