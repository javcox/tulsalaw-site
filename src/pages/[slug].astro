---
import CtaPanel from '../components/CtaPanel.astro';
import IntakePathPanel from '../components/IntakePathPanel.astro';
import PracticeCard from '../components/PracticeCard.astro';
import { firm, getServiceUrl, services, type Service } from '../data/site';
import Layout from '../layouts/Layout.astro';

export function getStaticPaths() {
	return services.map((service) => ({
		params: { slug: service.slug },
		props: { service },
	}));
}

const { service } = Astro.props as { service: Service };
const relatedServices = services.filter((entry) => service.related.includes(entry.slug));
const moneyPageServices = services.filter((entry) => service.moneyPageLinks?.includes(entry.slug));
const siblingSupportServices = services.filter((entry) => service.siblingSupportLinks?.includes(entry.slug));
const moneyPageLinks = services.filter((entry) => service.moneyPageLinks?.includes(entry.slug));
const siblingSupportLinks = services.filter((entry) => service.siblingSupportLinks?.includes(entry.slug));

const categoryCopy = {
	Guidance: {
		overview:
			'This is usually a fit when the issue needs attorney judgment before it can be placed in the right lane, filed, signed, or pushed further.',
		expectation:
			'Most legal guidance clients want a serious review of the facts, the pressure points, and the smartest next step before they commit more time or money.',
		consultation:
			'Legal guidance matters that fit usually move next to a paid consultation because they often require strategy review, document review, or attorney judgment before a recommendation can be be made.',
	},
	Planning: {
		overview:
			'This is usually a fit when the goal is to get important documents, authority decisions, or family planning handled before a crisis makes everything harder.',
		expectation:
			'Most planning clients are trying to avoid confusion later. The first question is usually whether the documents match the family, the assets, and the people who may have to act.',
		consultation:
			'Planning matters that fit often move next to a paid consultation when the work requires document review, family-structure analysis, or more customized strategy work.',
	},
	Family: {
		overview:
			'This is usually a fit when the matter involves family change, document preparation, filings, agreements, or a need for clearer next steps before tensions rise.',
		expectation:
			'Most family-law clients want to know what is urgent, what can wait, and what paperwork or decisions need attention first.',
		consultation:
			'Family-law matters that fit often move next to a paid consultation when the matter needs document review, strategy analysis, or review of existing filings or agreements.',
	},
	Injury: {
		overview:
			'This is usually a fit when the question is whether an injury matter has enough liability, treatment, insurance, and damages to justify moving forward.',
		expectation:
			'Most injury clients want an honest first look at fault, treatment, and whether the claim appears worth more time and attention.',
		consultation:
			'Personal injury matters are usually screened for fit first. If more detailed review is appropriate, the next step may include a paid review of liability, treatment history, documents, or claim materials before advice can be given.',
	},
	Business: {
		overview:
			'This is usually a fit when the work involves ownership, agreements, document cleanup, or business decisions that are better handled before they become disputes.',
		expectation:
			'Most business clients want to know whether the agreement, structure, or filing is sound enough to move forward without avoidable risk.',
		consultation:
			'Business matters that fit often move next to a paid consultation when contracts, company records, or transaction documents need to be reviewed before direction can be given.',
	},
} as const;

const currentCategory = categoryCopy[service.category as keyof typeof categoryCopy];

const schemas = [
	{
		'@context': 'https://schema.org',
		'@type': 'LegalService',
		name: service.name,
		url: `${firm.url}/${service.slug}/`,
		description: service.metaDescription,
		keywords: service.searchPhrases,
		provider: {
			'@type': 'Attorney',
			name: firm.legalName,
		},
		areaServed: ['Tulsa', 'Bixby', 'Broken Arrow', 'Oklahoma'],
		serviceType: service.name,
	},
	{
		'@context': 'https://schema.org',
		'@type': 'BreadcrumbList',
		itemListElement: [
			{
				'@type': 'ListItem',
				position: 1,
				name: 'Home',
				item: firm.url,
			},
			{
				'@type': 'ListItem',
				position: 2,
				name: service.name,
				item: `${firm.url}/${service.slug}/`,
			},
		],
	},
];
---

<Layout
	title={service.metaTitle}
	description={service.metaDescription}
	path={getServiceUrl(service.slug)}
	schemas={schemas}
>
	<section class="page-hero">
		<div class="shell page-frame">
			<div class="hero-card">
				<div class="breadcrumbs">
					<a href="/">Home</a>
					<span>/</span>
					<a href="/practice-areas/">Practice Areas</a>
					<span>/</span>
					<span>{service.name}</span>
				</div>
				<p class="eyebrow">{service.eyebrow}</p>
				<h1 class="page-title">{service.heroTitle}</h1>
				<p class="lead">
					{service.intro} {service.summary}
				</p>

				<div class="quick-facts">
					<span class="quick-fact">Tulsa office</span>
					<span class="quick-fact">Near Bixby and Broken Arrow</span>
					<span class="quick-fact">Attorney-led intake</span>
				</div>

				<div class="hero-actions">
					<a
						class="button button-primary"
						href={`/start-intake/?service=${service.slug}`}
						data-track="generate_lead"
						data-track-label={`${service.slug}-start-intake`}
					>
						Start Intake
					</a>
					<a class="button button-ghost" href="/contact/">Contact the firm</a>
				</div>
				<p class="mini-copy">This usually takes about 2 to 4 minutes and preselects {service.name.toLowerCase()} for the firm.</p>
			</div>

			<div class="hero-aside">
				<div class="panel">
					<p class="mini-kicker">Best fit</p>
					<ul class="checklist">
						{service.idealFor.map((item) => <li>{item}</li>)}
					</ul>
				</div>
				<IntakePathPanel />
			</div>
		</div>
	</section>

	<section class="section-xl">
		<div class="shell grid-2">
			<div class="band">
				<p class="eyebrow">What this can include</p>
				<h2 class="section-title">Common needs inside this matter type</h2>
				<ul class="checklist">
					{service.includes.map((item) => <li>{item}</li>)}
				</ul>
			</div>
			<div class="band">
				<p class="eyebrow">How the work usually moves</p>
				<h2 class="section-title">A cleaner path from first question to next step</h2>
				<ul class="checklist">
					{service.process.map((item) => <li>{item}</li>)}
				</ul>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="shell highlight-band">
			<div class="band">
				<p class="eyebrow">Before you reach out</p>
				<h2 class="section-title">What this page is helping you decide.</h2>
				<p class="lead" style="margin-top: 0;">
					{currentCategory.overview}
				</p>
			</div>
			<div class="band">
				<p class="section-label">Consultation note</p>
				<p class="lead" style="margin-top: 0;">
					Most requests are reviewed within 1 business day when submitted on a business day.
					{` ${currentCategory.consultation}`} Sending a request does not create an
					attorney-client relationship.
				</p>
				<div class="quote" style="margin-top: 18px;">
					{currentCategory.expectation}
				</div>
			</div>
		</div>
	</section>

	{service.localSupport && (
		<section class="section">
			<div class="shell highlight-band">
				<div class="band">
					<p class="eyebrow">Tulsa and Nearby</p>
					<h2 class="section-title">{service.localSupport.heading}</h2>
					<p class="lead" style="margin-top: 0;">{service.localSupport.copy}</p>
				</div>
				<div class="band">
					<p class="section-label">Local fit</p>
					<ul class="checklist" style="margin-top: 18px;">
						{service.localSupport.bullets.map((item) => <li>{item}</li>)}
					</ul>
				</div>
			</div>
		</section>
	)}

	{(moneyPageServices.length > 0 || siblingSupportServices.length > 0) && (
		<section class="section">
			<div class="shell">
				<div class="section-head">
					<div>
						<p class="eyebrow">Related Next Steps</p>
						<h2 class="section-title">Pages that help this matter make more sense</h2>
					</div>
				</div>
				<div class="service-grid">
					{moneyPageServices.map((entry) => <PracticeCard service={entry} />)}
					{siblingSupportServices.map((entry) => <PracticeCard service={entry} />)}
				</div>
			</div>
		</section>
	)}

	{service.localSupport && (
		<section class="section">
			<div class="shell local-support-card">
				<div>
					<p class="eyebrow">Local Fit</p>
					<h2 class="section-title">{service.localSupport.heading}</h2>
					<p class="lead" style="margin-top: 0;">{service.localSupport.copy}</p>
				</div>
				<ul class="checklist" style="margin-top: 0;">
					{service.localSupport.bullets.map((item) => <li>{item}</li>)}
				</ul>
			</div>
		</section>
	)}

	<section class="section">
		<div class="shell">
			<div class="section-head">
				<div>
					<p class="eyebrow">FAQ</p>
					<h2 class="section-title">Questions that come up before people reach out</h2>
				</div>
			</div>
			<div class="faq-list">
				{service.faqs.map((item) => (
					<div class="faq-item">
						<details>
							<summary>{item.question}</summary>
							<p>{item.answer}</p>
						</details>
					</div>
				))}
			</div>
		</div>
	</section>

	{(moneyPageLinks.length > 0 || siblingSupportLinks.length > 0) && (
		<section class="section">
			<div class="shell internal-link-grid">
				{moneyPageLinks.length > 0 && (
					<div class="band">
						<p class="eyebrow">Next Strong Match</p>
						<h2 class="section-title">Money pages closely tied to this topic</h2>
						<div class="chips">
							{moneyPageLinks.map((entry) => (
								<a class="chip" href={getServiceUrl(entry.slug)}>{entry.name}</a>
							))}
						</div>
					</div>
				)}
				{siblingSupportLinks.length > 0 && (
					<div class="band">
						<p class="eyebrow">Related Support</p>
						<h2 class="section-title">Support pages that help visitors choose the right next step</h2>
						<div class="chips">
							{siblingSupportLinks.map((entry) => (
								<a class="chip" href={getServiceUrl(entry.slug)}>{entry.name}</a>
							))}
							<a class="chip" href={`/start-intake/?service=${service.slug}`}>Start Intake</a>
						</div>
					</div>
				)}
			</div>
		</section>
	)}

	{relatedServices.length > 0 && (
		<section class="section-xl">
			<div class="shell">
				<div class="section-head">
					<div>
						<p class="eyebrow">Related Services</p>
						<h2 class="section-title">You may also want to review these related services.</h2>
					</div>
				</div>
				<div class="service-grid">
					{relatedServices.map((entry) => <PracticeCard service={entry} />)}
				</div>
			</div>
		</section>
	)}

	<CtaPanel
		title={`Ready to talk about ${service.name.toLowerCase()}?`}
		copy="Use the guided intake to send the matter for fit review and move it into the right queue."
		href={`/start-intake/?service=${service.slug}`}
	/>
</Layout>
