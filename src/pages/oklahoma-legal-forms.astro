---
import CtaPanel from '../components/CtaPanel.astro';
import PracticeCard from '../components/PracticeCard.astro';
import { featuredServices, firm } from '../data/site';
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Oklahoma Legal Documents and Simple Attorney Services"
	description="Tulsa Law focuses on common Oklahoma legal services like wills, powers of attorney, uncontested divorce matters, LLC formation, and contract review."
	path="/oklahoma-legal-forms/"
>
	<section class="page-hero">
		<div class="shell page-frame">
			<div class="hero-card">
				<div class="breadcrumbs">
					<a href="/">Home</a>
					<span>/</span>
					<span>Simple Services</span>
				</div>
				<p class="eyebrow">Simple Services</p>
				<h1 class="page-title">Oklahoma legal services built around the matters people often need first.</h1>
				<p class="lead">
					This page is for visitors who want a simpler path to legal help without sorting through
					an oversized list of practice areas. The strongest fit here is document-driven work that
					benefits from clear guidance, organized paperwork, and a direct next step.
				</p>
			</div>

			<div class="hero-aside">
				<div class="panel">
					<p class="mini-kicker">Best fit matters</p>
					<ul class="checklist">
						<li>Estate documents and planning updates</li>
						<li>Power of attorney and guardianship planning</li>
						<li>Uncontested-divorce and family-law document work</li>
						<li>LLC setup, operating agreements, and contract review</li>
					</ul>
				</div>
				<div class="panel">
					<p class="mini-kicker">Overview</p>
					<p class="mini-copy">
						If you already know the kind of help you need, this page lets you go straight to it.
						If you are not sure, use the contact page and describe the issue in plain language.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="section-xl">
		<div class="shell service-grid">
			{featuredServices.map((service) => <PracticeCard service={service} />)}
		</div>
	</section>

	<section class="section">
		<div class="shell grid-2">
			<div class="band">
				<p class="eyebrow">Good fit</p>
				<h2 class="section-title">This page may be a good fit if you need help with:</h2>
				<ul class="checklist">
					<li>You need planning documents, not a DIY packet with no attorney review.</li>
					<li>You want clearer business or family paperwork before the matter gets messier.</li>
					<li>You want direct guidance from a Tulsa attorney serving Oklahoma clients.</li>
				</ul>
			</div>
			<div class="band">
				<p class="eyebrow">Start Here</p>
				<h2 class="section-title">If you are not sure where your matter fits, begin with the closest service and contact the office from there.</h2>
				<ul class="checklist">
					<li>Choose the service that sounds closest to your issue.</li>
					<li>Use the contact page if you would rather explain the matter first.</li>
					<li>The office can help determine whether the issue is a good fit for consultation.</li>
				</ul>
			</div>
		</div>
	</section>

	<CtaPanel
		title="Ready to talk about your matter?"
		copy={`Call ${firm.phoneDisplay}, send an email, or use the secure intake page to describe the issue in plain language and request a consultation.`}
	/>
</Layout>
