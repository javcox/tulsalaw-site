---
import CtaPanel from '../components/CtaPanel.astro';
import PracticeCard from '../components/PracticeCard.astro';
import { featuredServices, firm } from '../data/site';
import Layout from '../layouts/Layout.astro';

const simpleServices = featuredServices.filter(
	(service) => !['personal-injury', 'legal-guidance'].includes(service.slug),
);
---

<Layout
	title="Oklahoma Legal Documents and Simple Attorney Services"
	description="Tulsa Law focuses on common Oklahoma legal services like wills, powers of attorney, uncontested divorce matters, LLC formation, and contract review."
	path="/oklahoma-legal-forms/"
>
	<section class="page-hero">
		<div class="shell page-frame">
			<div class="hero-card">
				<div class="breadcrumbs">
					<a href="/">Home</a>
					<span>/</span>
					<span>Simple Services</span>
				</div>
				<p class="eyebrow">Simple Services</p>
				<h1 class="page-title">Oklahoma legal services built around the matters people often need first.</h1>
				<p class="lead">
					Simple Services is the shorter route for document-focused matters. It is strongest for
					estate planning, powers of attorney, guardianship planning, uncontested-divorce
					paperwork, LLC formation, and contract review. Use Personal Injury Review for injury
					matters, Legal Guidance when the lane is still unclear, and Practice Areas when you want
					the broader service map. Many matters that fit move next to the $100 30-minute
					consultation path after intake review.
				</p>
			</div>

			<div class="hero-aside">
				<div class="panel">
					<p class="mini-kicker">Use Simple Services when</p>
					<ul class="checklist">
						<li>Estate documents and planning updates</li>
						<li>Power of attorney and guardianship planning</li>
						<li>Uncontested-divorce and family-law document work</li>
						<li>LLC setup, operating agreements, and contract review</li>
					</ul>
				</div>
				<div class="panel">
					<p class="mini-kicker">Choose a different path if</p>
					<ul class="checklist">
						<li>The issue is an injury claim that needs liability and damages review first.</li>
						<li>You are not sure whether the matter belongs in planning, family, business, or injury review.</li>
						<li>You want the broader service map instead of the shorter document route.</li>
					</ul>
					<div class="chips">
						<a class="chip" href="/personal-injury/">Personal Injury Review</a>
						<a class="chip" href="/legal-guidance/">Legal Guidance</a>
						<a class="chip" href="/practice-areas/">Practice Areas</a>
					</div>
				</div>
			</div>
		</div>
	</section>

	<section class="section-xl">
		<div class="shell service-grid">
			{simpleServices.map((service) => <PracticeCard service={service} />)}
		</div>
	</section>

	<section class="section">
		<div class="shell grid-2">
			<div class="band">
				<p class="eyebrow">Good fit</p>
				<h2 class="section-title">This page may be a good fit if you need help with:</h2>
				<ul class="checklist">
					<li>You need planning documents, not a DIY packet with no attorney review.</li>
					<li>You want clearer business or family paperwork before the matter gets messier.</li>
					<li>You want direct guidance from a Tulsa attorney serving Oklahoma clients.</li>
				</ul>
			</div>
			<div class="band">
				<p class="eyebrow">Need a wider route?</p>
				<h2 class="section-title">Use a broader path when the matter is not mostly document-focused.</h2>
				<ul class="checklist">
					<li>Use Legal Guidance if the issue crosses lanes or the next step is still unclear.</li>
					<li>Use Practice Areas if you want the broader family, business, and planning map.</li>
					<li>Use the guided intake if you would rather let the office route the matter after fit review.</li>
				</ul>
				<div class="chips">
					<a class="chip" href="/legal-guidance/">Legal Guidance</a>
					<a class="chip" href="/practice-areas/">Practice Areas</a>
					<a class="chip" href={firm.consultationUrl}>Start Intake</a>
				</div>
			</div>
		</div>
	</section>

	<CtaPanel
		title="Ready to send a document-focused matter in for review?"
		copy="Use the guided intake when you want the shorter route for planning documents, uncontested-divorce paperwork, LLC formation, or contract review."
	/>
</Layout>
