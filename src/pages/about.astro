---
import AttorneySpotlight from '../components/AttorneySpotlight.astro';
import CtaPanel from '../components/CtaPanel.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import WhyChooseSection from '../components/WhyChooseSection.astro';
import { firm } from '../data/site';
import Layout from '../layouts/Layout.astro';

const schemas = [
	{
		'@context': 'https://schema.org',
		'@type': 'ProfilePage',
		name: 'About Tracy A. Cinocca',
		mainEntity: {
			'@type': 'Person',
			name: 'Tracy A. Cinocca',
			jobTitle: 'Attorney',
			alumniOf: [
				'University of Tulsa',
				'Oklahoma City University',
				'University of Oklahoma',
				'Villanova University',
			],
			worksFor: {
				'@type': 'LegalService',
				name: firm.legalName,
			},
		},
	},
];
---

<Layout
	title="About Tracy A. Cinocca | Tulsa Attorney Serving Oklahoma"
	description="Learn about Tracy A. Cinocca, JD, MBA, and the experience behind Tulsa Law's estate planning, personal injury, family law, and business-document practice."
	path="/about/"
	schemas={schemas}
>
	<section class="page-hero">
		<div class="shell page-frame">
			<div class="hero-card">
				<div class="breadcrumbs">
					<a href="/">Home</a>
					<span>/</span>
					<span>About Tracy</span>
				</div>
				<p class="eyebrow">About Tracy</p>
				<h1 class="page-title">A Tulsa attorney with legal depth and practical business instinct.</h1>
				<p class="lead">
					Tracy A. Cinocca's background blends legal training, MBA-level business understanding,
					and real contract and acquisition experience. That combination helps clients make better
					decisions when the stakes touch family, money, ownership, and future planning.
				</p>
				<div class="pill-row">
					{firm.credentials.map((credential) => <span class="pill">{credential}</span>)}
				</div>
			</div>

			<div class="hero-aside">
				<div class="panel">
					<p class="mini-kicker">Practice approach</p>
					<h2 class="mini-title">Clear advice and careful preparation.</h2>
					<p class="mini-copy">
						Many matters are easier to handle when clients get advice early, before paperwork or
						family and business issues become harder to fix.
					</p>
				</div>
				<div class="panel">
					<p class="mini-kicker">Service area</p>
					<h2 class="mini-title">Based in Tulsa near Bixby, serving clients across Oklahoma.</h2>
					<p class="mini-copy">
						The practice includes estate planning, personal injury matters, family-law matters,
						and business documents for clients throughout Oklahoma, including nearby Bixby and
						Broken Arrow.
					</p>
				</div>
			</div>
		</div>
	</section>

	<AttorneySpotlight />

	<section class="section-xl">
		<div class="shell">
			<div class="section-head">
				<div>
					<p class="eyebrow">What stands out</p>
					<h2 class="section-title">The background behind the legal judgment</h2>
				</div>
			</div>

			<div class="grid-3">
				{firm.bioHighlights.map((item) => (
					<div class="value-card">
						<h3>Client-facing advantage</h3>
						<p>{item}</p>
					</div>
				))}
			</div>
		</div>
	</section>

	<section class="section">
		<div class="shell">
			<div class="section-head">
				<div>
					<p class="eyebrow">Education + foundation</p>
					<h2 class="section-title">A path that blends legal, business, and analytical training</h2>
				</div>
			</div>

			<div class="timeline">
				<div class="card">
					<h3>University of Tulsa</h3>
					<p>Law degree completed in 1997.</p>
				</div>
				<div class="card">
					<h3>Oklahoma City University</h3>
					<p>MBA completed in 1994 while working full-time in purchasing and acquisitions.</p>
				</div>
				<div class="card">
					<h3>University of Oklahoma</h3>
					<p>BA completed in 1993.</p>
				</div>
				<div class="card">
					<h3>Villanova University</h3>
					<p>Additional mathematics and science studies, including physics coursework.</p>
				</div>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="shell highlight-band">
			<div class="band">
				<p class="eyebrow">Working style</p>
				<h2 class="section-title">What clients can expect from the process</h2>
				<ul class="checklist">
					{firm.brandPillars.map((item) => <li>{item}</li>)}
				</ul>
			</div>

			<div class="band">
				<p class="section-label">Client perspective</p>
				<p class="lead" style="margin-top: 0;">
					Estate documents, family-law paperwork, and business agreements are often used at
					important moments. Clients should understand what the documents do, what choices they
					are making, and what comes next.
				</p>
				<div class="quote" style="margin-top: 18px;">
					The goal is simple: clients should feel informed before they sign anything important.
				</div>
			</div>
		</div>
	</section>

	<WhyChooseSection />
	<TestimonialsSection />

	<CtaPanel
		title="Want to send a matter in for review?"
		copy="Use the guided intake to route the matter for fit review, or email the firm directly if you need to add a quick note first."
	/>
</Layout>
