---
import AttorneySpotlight from '../components/AttorneySpotlight.astro';
import CtaPanel from '../components/CtaPanel.astro';
import IntakePathPanel from '../components/IntakePathPanel.astro';
import PracticeCard from '../components/PracticeCard.astro';
import PracticeAreasCard from '../components/PracticeAreasCard.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import WhyChooseSection from '../components/WhyChooseSection.astro';
import { featuredServices, firm, homepageFAQs, homepageLanes } from '../data/site';
import Layout from '../layouts/Layout.astro';

const trustItems = ['Tulsa office', '2-4 minute intake', 'Attorney-led review', 'Reviewed within 1 business day'];

const browseLinks = [
	{ label: 'Practice Areas', href: '/practice-areas/' },
	{ label: 'Simple Services', href: '/oklahoma-legal-forms/' },
];

const schemas = [
	{
		'@context': 'https://schema.org',
		'@type': 'LegalService',
		name: `${firm.name} | ${firm.legalName}`,
		url: firm.url,
		areaServed: ['Tulsa', 'Bixby', 'Broken Arrow', 'Oklahoma'],
		email: firm.email,
		description: firm.tagline,
		serviceType: [
			'Personal injury review',
			'Legal guidance',
			'Estate planning',
			'Power of attorney',
			'Wills and trusts',
			'Guardianship planning',
			'Uncontested divorce',
			'LLC formation',
			'Contract drafting and review',
		],
		address: {
			'@type': 'PostalAddress',
			streetAddress: firm.streetAddress,
			addressLocality: firm.city,
			addressRegion: firm.region,
			postalCode: firm.postalCode,
			addressCountry: 'US',
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'ItemList',
		name: 'Tulsa Law homepage service lanes',
		itemListElement: homepageLanes.map((lane, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			name: lane.title,
			url: new URL(lane.href, firm.url).toString(),
		})),
	},
];
---

<Layout
	title="Tulsa Lawyer for Personal Injury Review, Estate Planning, and Clear Legal Guidance"
	description="Tulsa Law is a Tulsa-based Oklahoma law office focused on personal injury review, estate planning, legal guidance, and clear next steps for clients across Tulsa, Bixby, Broken Arrow, and Oklahoma."
	path="/"
	schemas={schemas}
>
	<section class="hero">
		<div class="shell hero-grid">
			<div class="hero-card">
				<p class="eyebrow">Tulsa office. Attorney-led review. Clear next steps.</p>
				<h1 class="hero-title">
					Tulsa lawyer for personal injury review, estate planning, and clear legal guidance.
				</h1>
				<p class="lead">
					If you need to know whether an injury matter is worth pursuing, what documents need
					attention, or what should happen next, start the intake. Most requests are reviewed
					within 1 business day, and you do not need to write a long memo before you begin.
				</p>

				<div class="hero-actions">
					<a
						class="button button-primary"
						href={firm.consultationUrl}
						data-track="generate_lead"
						data-track-label="home-start-intake"
					>
						Start Intake
					</a>
					<a class="button button-ghost" href="/practice-areas/">See Practice Areas</a>
				</div>
				<p class="mini-copy">
					Most people finish intake in 2 to 4 minutes. Personal injury matters are screened for
					fit first. If you are not sure which lane fits, choose Legal Guidance.
				</p>

				<div class="trust-strip" aria-label="Trust indicators">
					{trustItems.map((item) => <span>{item}</span>)}
				</div>

				<div class="hero-meta hero-meta-lanes">
					{homepageLanes.map((lane, index) => (
						<a class="stat-card lane-stat" href={lane.href}>
							<strong>{`0${index + 1}`} {lane.title}</strong>
							<span>{lane.copy}</span>
						</a>
					))}
				</div>
			</div>

			<div class="hero-aside">
				<div class="panel">
					<p class="mini-kicker">Before you submit</p>
					<h2 class="mini-title">What the office looks for first.</h2>
					<p class="mini-copy">
						The intake is built to route the matter into the right review lane without pushing
						anyone into a call before the facts are clear.
					</p>
					<ul class="checklist">
						<li>Personal injury matters are screened for fit first.</li>
						<li>Many non-injury matters that fit move next to the $100 30-minute consultation path.</li>
						<li>The office reviews fit, timing, conflicts, and urgency before the next step is offered.</li>
					</ul>
					<p class="section-label" style="margin-top: 18px;">Need the wider map?</p>
					<div class="chips">
						{
							browseLinks.map((item) => (
								<a class="chip" href={item.href}>
									{item.label}
								</a>
							))
						}
					</div>
					<p class="mini-copy office-copy">
						Tulsa office serving Tulsa, Bixby, Broken Arrow, and nearby communities: {firm.fullAddress}
					</p>
				</div>

				<IntakePathPanel />
			</div>
		</div>
	</section>

	<section class="section">
		<div class="shell highlight-band">
			<div class="band">
				<p class="eyebrow">What Happens Next</p>
				<h2 class="section-title">A clearer intake path from first request to follow-up.</h2>
				<ul class="checklist">
					<li>Start Intake and choose the lane that best fits the matter.</li>
					<li>The firm reviews fit, timing, conflicts, and urgency.</li>
					<li>Personal injury matters are screened first for whether the claim appears worth pursuing.</li>
					<li>Most planning, family, business, and legal-guidance matters that fit move next to an email with scheduling instructions for the $100 30-minute consultation.</li>
				</ul>
			</div>
			<div class="band">
				<p class="section-label">Before you submit</p>
				<p class="lead" style="margin-top: 0;">
					The intake is meant to save time, not create a high-pressure funnel. You do not need to
					write a long memo, upload documents, or guess the legal strategy before reaching out.
				</p>
				<div class="quote" style="margin-top: 18px;">
					This site is built for attorney review, not instant free legal advice. It is strongest for
					Tulsa, Bixby, Broken Arrow, and nearby Oklahoma matters that fit the listed practice areas
					and current availability.
				</div>
			</div>
		</div>
	</section>

	<section class="section-xl">
		<div class="shell">
			<div class="section-head">
				<div>
					<p class="eyebrow">Most Requested</p>
					<h2 class="section-title">Core pages people usually choose first</h2>
					<p class="section-copy">
						These are the highest-intent entry pages for the site. The separate catch-all card
						keeps the rest of the practice map available without turning the homepage into a long
						list of unrelated services.
					</p>
				</div>
			</div>

			<div class="service-grid">
				{featuredServices.map((service) => <PracticeCard service={service} />)}
				<PracticeAreasCard />
			</div>
		</div>
	</section>

	<AttorneySpotlight />

	<section class="section-xl">
		<div class="shell">
			<div class="section-head">
				<div>
					<p class="eyebrow">Client Fit</p>
					<h2 class="section-title">What clients usually want when they start here</h2>
					<p class="section-copy">
						Most people reaching out are trying to answer a practical question before the matter
						gets more expensive, more stressful, or harder to fix later.
					</p>
				</div>
			</div>

			<div class="grid-3">
				<div class="value-card">
					<h3>Do I have an injury matter worth pursuing?</h3>
					<p>
						People who need an honest review of liability, treatment, insurance, and damages before
						they spend months chasing the wrong claim.
					</p>
				</div>
				<div class="value-card">
					<h3>Which document or legal path actually fits?</h3>
					<p>
						Clients who need attorney judgment on planning, family, business, or broader legal
						guidance before signing, filing, or escalating anything important.
					</p>
				</div>
				<div class="value-card">
					<h3>Can this be handled cleanly before it gets messy?</h3>
					<p>
						Families and business owners who want wills, powers of attorney, uncontested-divorce
						paperwork, LLC setup, or contract review handled with more care than a template or
						filing service can offer.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="shell highlight-band">
			<div class="band">
				<p class="eyebrow">Service Area</p>
				<h2 class="section-title">Tulsa office serving Tulsa, Bixby, Broken Arrow, and nearby communities.</h2>
				<p class="lead" style="margin-top: 0;">
					The office is in south Tulsa, making it a practical nearby option for clients in Tulsa,
					Bixby, Broken Arrow, and surrounding communities who want direct attorney review.
				</p>
			</div>
			<div class="band">
				<p class="section-label">Where this matters most</p>
				<ul class="checklist" style="margin-top: 18px;">
					<li>Estate planning for families who want documents done correctly instead of relying on generic online forms</li>
					<li>Uncontested divorce and legal guidance for households in south Tulsa and nearby communities looking for a calmer process</li>
					<li>LLC formation and contract help for owners working across Tulsa, Bixby, Broken Arrow, and nearby business corridors</li>
				</ul>
			</div>
		</div>
	</section>

	<WhyChooseSection />
	<TestimonialsSection />

	<section class="section">
		<div class="shell">
			<div class="section-head">
				<div>
					<p class="eyebrow">FAQ</p>
					<h2 class="section-title">The questions most visitors need answered before they reach out</h2>
				</div>
			</div>

			<div class="faq-list">
				{
					homepageFAQs.map((item) => (
						<div class="faq-item">
							<details>
								<summary>{item.question}</summary>
								<p>{item.answer}</p>
							</details>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<CtaPanel
		title="Ready to send a matter in for review?"
		copy="Use the guided intake to route the matter into the right review lane and get clearer next steps without waiting on a call-back loop."
	/>
</Layout>
