---
import AttorneySpotlight from '../components/AttorneySpotlight.astro';
import CtaPanel from '../components/CtaPanel.astro';
import IntakeExpectationsSection from '../components/IntakeExpectationsSection.astro';
import IntakePathPanel from '../components/IntakePathPanel.astro';
import PracticeCard from '../components/PracticeCard.astro';
import PracticeAreasCard from '../components/PracticeAreasCard.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import WhyChooseSection from '../components/WhyChooseSection.astro';
import { featuredServices, firm, getServiceUrl, homepageFAQs } from '../data/site';
import Layout from '../layouts/Layout.astro';

const mapLinks = [
	{ label: 'Personal Injury', href: getServiceUrl('personal-injury') },
	{ label: 'Estate Planning', href: getServiceUrl('estate-planning') },
	{ label: 'Legal Guidance', href: getServiceUrl('legal-guidance') },
	{ label: 'Power of Attorney', href: getServiceUrl('power-of-attorney') },
	{ label: 'Uncontested Divorce', href: getServiceUrl('uncontested-divorce') },
	{ label: 'LLC Formation', href: getServiceUrl('llc-formation') },
	{ label: 'Contracts', href: getServiceUrl('contract-drafting-review') },
	{ label: 'More Practice Areas', href: '/practice-areas/' },
];

const schemas = [
	{
		'@context': 'https://schema.org',
		'@type': 'LegalService',
		name: `${firm.name} | ${firm.legalName}`,
		url: firm.url,
		areaServed: ['Tulsa', 'Oklahoma'],
		email: firm.email,
		description: firm.tagline,
		serviceType: [
			'Legal guidance',
			'Estate planning',
			'Power of attorney',
			'Personal injury',
			'Car accidents',
			'Truck accidents',
			'Guardianship planning',
			'Uncontested divorce',
			'LLC formation',
			'Contract drafting and review',
		],
	},
];
---

<Layout
	title="Tulsa Attorney for Personal Injury Review, Legal Guidance, and Estate Planning"
	description="Tulsa Law is a Tulsa-based Oklahoma legal site focused on personal injury review, practical legal guidance, estate planning, family matters, and business documents."
	path="/"
	schemas={schemas}
>
	<section class="hero">
		<div class="shell hero-grid">
			<div class="hero-card">
				<p class="eyebrow">Tulsa-based. Oklahoma-wide.</p>
				<h1 class="hero-title">
					Personal injury review, practical legal guidance, and estate planning with a clearer next step.
				</h1>
				<p class="lead">
					Most people who land here are trying to solve one of three problems: they need an
					injury matter screened quickly, they need practical legal guidance on a family or
					business issue, or they need estate documents handled before a problem grows. Practice
					Areas is the full service map. Simple Services is the faster document-focused path.
				</p>

				<div class="hero-actions">
					<a
						class="button button-primary"
						href={firm.consultationUrl}
						data-track="generate_lead"
						data-track-label="home-contact"
					>
						Request a Consultation
					</a>
					<a
						class="button button-secondary"
						href={firm.emailHref}
						data-track="generate_lead"
						data-track-label="home-email"
					>
						Email the Firm
					</a>
				</div>

				<div class="hero-meta">
					<div class="stat-card">
						<strong>01 Personal injury review</strong>
						<span>For collision and injury matters where liability, treatment, and damages need a serious first look.</span>
					</div>
					<div class="stat-card">
						<strong>02 Legal guidance</strong>
						<span>For family, business, and active matters that need a clear next step instead of guesswork.</span>
					</div>
					<div class="stat-card">
						<strong>03 Estate planning</strong>
						<span>For wills, trusts, powers of attorney, and planning decisions that should be handled before a crisis.</span>
					</div>
				</div>
			</div>

			<div class="hero-aside">
				<div class="panel">
					<p class="mini-kicker">Practice Areas</p>
					<h2 class="mini-title">The full service map.</h2>
					<p class="mini-copy">
						Practice Areas covers the full range of injury, planning, family, and business work.
						Simple Services is the faster path for document-driven matters.
					</p>
					<div class="chips">
						{
							mapLinks.map((item) => (
								<a class="chip" href={item.href}>
									{item.label}
								</a>
							))
						}
					</div>
					<p class="mini-copy office-copy">
						Tulsa office: {firm.fullAddress}
					</p>
				</div>

				<IntakePathPanel />
			</div>
		</div>
	</section>

	<section class="section-xl">
		<div class="shell">
			<div class="section-head">
				<div>
					<p class="eyebrow">Most Requested</p>
					<h2 class="section-title">The legal services people most often ask about first</h2>
				</div>
			</div>

			<div class="service-grid">
				{featuredServices.map((service) => <PracticeCard service={service} />)}
				<PracticeAreasCard />
			</div>
		</div>
	</section>

	<AttorneySpotlight />

	<section class="section-xl">
		<div class="shell">
			<div class="section-head">
				<div>
					<p class="eyebrow">Client Fit</p>
					<h2 class="section-title">Who this site is built to help first</h2>
				</div>
			</div>

			<div class="grid-3">
				<div class="value-card">
					<h3>Families planning ahead</h3>
					<p>
						Clients who need wills, trusts, powers of attorney, guardianship decisions, and a
						more organized estate plan.
					</p>
				</div>
				<div class="value-card">
					<h3>People navigating change</h3>
					<p>
						Clients dealing with family-law transitions who want cleaner paperwork and clearer
						next steps instead of confusion.
					</p>
				</div>
				<div class="value-card">
					<h3>Owners protecting the business side</h3>
					<p>
						Founders and business owners who want LLC setup, operating agreements, and contracts
						done with more care than a filing service can offer.
					</p>
				</div>
			</div>
		</div>
	</section>

	<WhyChooseSection />
	<TestimonialsSection />
	<IntakeExpectationsSection />

	<section class="section">
		<div class="shell">
			<div class="section-head">
				<div>
					<p class="eyebrow">FAQ</p>
					<h2 class="section-title">The questions most visitors need answered before they reach out</h2>
				</div>
			</div>

			<div class="faq-list">
				{
					homepageFAQs.map((item) => (
						<div class="faq-item">
							<details>
								<summary>{item.question}</summary>
								<p>{item.answer}</p>
							</details>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<CtaPanel
		title="Ready to send a matter in for review?"
		copy="Use the guided intake to route the matter for fit review, or email the firm directly if you need to explain a detail first."
	/>
</Layout>
