---
import CtaPanel from '../components/CtaPanel.astro';
import PracticeCard from '../components/PracticeCard.astro';
import { featuredServices, firm, homepageFAQs } from '../data/site';
import Layout from '../layouts/Layout.astro';

const schemas = [
	{
		'@context': 'https://schema.org',
		'@type': 'LegalService',
		name: `${firm.name} | ${firm.legalName}`,
		url: firm.url,
		areaServed: ['Tulsa', 'Oklahoma'],
		email: firm.email,
		description: firm.tagline,
		serviceType: [
			'Estate planning',
			'Power of attorney',
			'Guardianship planning',
			'Uncontested divorce',
			'LLC formation',
			'Contract drafting and review',
		],
	},
];
---

<Layout
	title="Tulsa Attorney for Wills, Divorce Filings, Business Formation, and Everyday Legal Matters"
	description="Tulsa Law is a modern Oklahoma legal site focused on wills, trusts, powers of attorney, guardianship planning, family-law filings, LLC formation, and contract review."
	path="/"
	schemas={schemas}
>
	<section class="hero">
		<div class="shell hero-grid">
			<div class="hero-card">
				<p class="eyebrow">Tulsa-based. Oklahoma-wide.</p>
				<h1 class="hero-title">
					Modern legal help for the documents and decisions people need handled now.
				</h1>
				<p class="lead">
					Tulsa Law is built around the matters that often turn into urgent intake requests:
					wills, trusts, powers of attorney, guardianship planning, uncontested-divorce paths,
					LLC formation, and contract review. The goal is simple: clearer documents, cleaner
					next steps, and direct attorney guidance.
				</p>

				<div class="hero-actions">
					<a
						class="button button-primary"
						href="/contact/"
						data-track="generate_lead"
						data-track-label="home-contact"
					>
						Request a Consultation
					</a>
					<a
						class="button button-secondary"
						href={firm.emailHref}
						data-track="generate_lead"
						data-track-label="home-email"
					>
						Email the Firm
					</a>
				</div>

				<div class="hero-meta">
					<div class="stat-card">
						<strong>Estate + Family + Business</strong>
						<span>Focused on the legal matters clients most commonly bring to the firm.</span>
					</div>
					<div class="stat-card">
						<strong>JD + MBA perspective</strong>
						<span>Helpful when documents affect money, ownership, and long-range planning.</span>
					</div>
					<div class="stat-card">
						<strong>Clear intake path</strong>
						<span>Email or secure consultation request through the main firm intake.</span>
					</div>
				</div>
			</div>

			<div class="hero-aside">
				<div class="panel">
					<p class="mini-kicker">Services</p>
					<h2 class="mini-title">Common matters.</h2>
					<p class="mini-copy">
						These are some of the matters people most often contact the firm about.
					</p>
					<div class="chips">
						<span class="chip">Wills</span>
						<span class="chip">Trusts</span>
						<span class="chip">Power of Attorney</span>
						<span class="chip">Guardianship</span>
						<span class="chip">Uncontested Divorce</span>
						<span class="chip">LLC Formation</span>
						<span class="chip">Contracts</span>
					</div>
				</div>

				<div class="panel">
					<p class="mini-kicker">Contact</p>
					<h2 class="mini-title">Choose the best way to get in touch.</h2>
					<p class="mini-copy">
						If you already know the service you need, go straight to that page. If not, send
						an email or request a consultation and describe the situation.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="section-xl">
		<div class="shell">
			<div class="section-head">
				<div>
					<p class="eyebrow">Most Requested</p>
					<h2 class="section-title">The legal services people most often ask about first</h2>
				</div>
			</div>

			<div class="service-grid">
				{featuredServices.map((service) => <PracticeCard service={service} />)}
			</div>
		</div>
	</section>

	<section class="section">
		<div class="shell highlight-band">
			<div class="band">
				<p class="eyebrow">About the attorney</p>
				<h2 class="section-title">Real credentials, practical judgment, and a sharper business lens.</h2>
				<p class="lead">
					Tracy A. Cinocca brings together legal training, MBA-level business perspective, and
					experience that helps clients think about documents in the real world, not just on paper.
				</p>
				<ul class="checklist">
					{firm.credentials.map((credential) => <li>{credential}</li>)}
				</ul>
			</div>

			<div class="band">
				<p class="section-label">Approach</p>
				<div class="split-copy">
					<div>
						<h3>Practical legal help</h3>
						<p>
							The site is organized so visitors can quickly find the service that fits their
							matter and contact the office without sorting through unnecessary material.
						</p>
					</div>
					<div>
						<h3>Straightforward communication</h3>
						<p>
							The goal is to explain the process clearly, prepare documents carefully, and help
							clients understand what comes next.
						</p>
					</div>
				</div>
				<div class="quote" style="margin-top: 18px;">
					Clients should understand the plan, the paperwork, and the next step before they sign
					anything important.
				</div>
			</div>
		</div>
	</section>

	<section class="section-xl">
		<div class="shell">
			<div class="section-head">
				<div>
					<p class="eyebrow">Client Fit</p>
					<h2 class="section-title">Who this site is built to help first</h2>
				</div>
			</div>

			<div class="grid-3">
				<div class="value-card">
					<h3>Families planning ahead</h3>
					<p>
						Clients who need wills, trusts, powers of attorney, guardianship decisions, and a
						more organized estate plan.
					</p>
				</div>
				<div class="value-card">
					<h3>People navigating change</h3>
					<p>
						Clients dealing with family-law transitions who want cleaner paperwork and clearer
						next steps instead of confusion.
					</p>
				</div>
				<div class="value-card">
					<h3>Owners protecting the business side</h3>
					<p>
						Founders and business owners who want LLC setup, operating agreements, and contracts
						done with more care than a filing service can offer.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="section">
		<div class="shell">
			<div class="section-head">
				<div>
					<p class="eyebrow">FAQ</p>
					<h2 class="section-title">The questions most visitors need answered before they reach out</h2>
				</div>
			</div>

			<div class="faq-list">
				{
					homepageFAQs.map((item) => (
						<div class="faq-item">
							<details>
								<summary>{item.question}</summary>
								<p>{item.answer}</p>
							</details>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<CtaPanel
		title="Ready to send a matter in for review?"
		copy="Use the contact page to email the firm or route the consultation through the main secure intake form."
	/>
</Layout>
