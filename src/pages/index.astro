---
import AttorneySpotlight from '../components/AttorneySpotlight.astro';
import CtaPanel from '../components/CtaPanel.astro';
import TestimonialsSection from '../components/TestimonialsSection.astro';
import { firm, homepageFAQs, homepageLanes } from '../data/site';
import Layout from '../layouts/Layout.astro';

const trustItems = ['Tulsa office', '2-4 minute intake', 'Attorney-led review', 'Reviewed within 1 business day'];

const heroFitItems = [
	{
		title: 'Personal injury review',
		copy: 'Car, truck, motorcycle, pedestrian, and related injury matters that need an attorney look at liability, treatment, and damages.',
	},
	{
		title: 'Estate planning',
		copy: 'Wills, trusts, powers of attorney, guardianship planning, and document updates that should be handled carefully and cleanly.',
	},
	{
		title: 'Legal guidance',
		copy: 'Family, business, contract, and LLC matters where the next practical step should be clear before anything gets signed, filed, or escalated.',
	},
];

const afterIntakeSteps = [
	'Choose the closest lane so the matter moves into the right review queue.',
	'Send only the core facts. Most people finish intake in about 2 to 4 minutes.',
	'Watch for attorney review. Personal injury is screened for fit first, and many non-injury matters that fit move next to the $100 30-minute consultation path.',
];

const practicalPathBullets = [
	'Tulsa-based attorney-led review instead of a generic intake handoff',
	'A guided intake designed to stay practical instead of asking for a long written story',
	'Clearer next-step guidance for injury, planning, family, business, and document matters',
	'Fit, conflicts, scope, and current availability are reviewed before the next step is offered',
];

const homepageRoutes = [
	...homepageLanes.map((lane) => ({
		title: lane.title,
		href: lane.href,
		copy: lane.copy,
		tag: ['Personal Injury Review', 'Estate Planning', 'Legal Guidance'].includes(lane.title)
			? 'Main lane'
			: 'Broader map',
		links: lane.links,
		footer:
			lane.title === 'More Practice Areas'
				? 'Browse the broader service map'
				: `Start with ${lane.title}`,
	})),
];

const schemas = [
	{
		'@context': 'https://schema.org',
		'@type': 'LegalService',
		name: `${firm.name} | ${firm.legalName}`,
		url: firm.url,
		areaServed: ['Tulsa', 'Bixby', 'Broken Arrow', 'Oklahoma'],
		email: firm.email,
		description: firm.tagline,
		serviceType: [
			'Personal injury review',
			'Legal guidance',
			'Estate planning',
			'Power of attorney',
			'Wills and trusts',
			'Guardianship planning',
			'Uncontested divorce',
			'LLC formation',
			'Contract drafting and review',
		],
		address: {
			'@type': 'PostalAddress',
			streetAddress: firm.streetAddress,
			addressLocality: firm.city,
			addressRegion: firm.region,
			postalCode: firm.postalCode,
			addressCountry: 'US',
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'ItemList',
		name: 'Tulsa Law homepage service lanes',
		itemListElement: homepageLanes.map((lane, index) => ({
			'@type': 'ListItem',
			position: index + 1,
			name: lane.title,
			url: new URL(lane.href, firm.url).toString(),
		})),
	},
];
---

<Layout
	title="Tulsa Lawyer for Personal Injury Review, Estate Planning, and Clear Legal Guidance"
	description="Tulsa Law is a Tulsa-based Oklahoma law office focused on personal injury review, estate planning, legal guidance, and clear next steps for clients across Tulsa, Bixby, Broken Arrow, and Oklahoma."
	path="/"
	schemas={schemas}
>
	<section class="hero">
		<div class="shell hero-grid">
			<div class="hero-card hero-home-card">
				<p class="eyebrow">Tulsa office. Attorney-led review. Clear next steps.</p>
				<h1 class="hero-title">Tulsa attorney for injury review, planning, and legal guidance.</h1>
				<p class="lead">
					Use the guided intake for personal injury review, estate planning, powers of attorney,
					guardianship, and practical family, business, or document matters. Most requests are
					reviewed within 1 business day.
				</p>
				<p class="hero-summary">
					Most people finish in about 2 to 4 minutes, and you do not need to write a long memo
					before you begin.
				</p>

				<div class="hero-actions">
					<a
						class="button button-primary"
						href={firm.consultationUrl}
						data-track="generate_lead"
						data-track-label="home-start-intake"
					>
						Start Intake
					</a>
					<a class="button button-ghost" href="/practice-areas/">See Practice Areas</a>
				</div>
				<p class="mini-copy hero-support-copy">
					If you are not sure which lane fits, choose Legal Guidance.
				</p>

				<div class="trust-strip" aria-label="Trust indicators">
					{trustItems.map((item) => <span>{item}</span>)}
				</div>
			</div>

			<div class="hero-aside">
				<div class="panel hero-review-panel">
					<p class="mini-kicker">Choose the closest first path</p>
					<h2 class="mini-title">The homepage stays focused on three main lanes.</h2>
					<div class="hero-fit-list">
						{
							heroFitItems.map((item) => (
								<div class="hero-fit-item">
									<strong>{item.title}</strong>
									<p>{item.copy}</p>
								</div>
						))
					}
					</div>
					<p class="hero-support-note">
						Use Practice Areas when the issue falls outside the three main homepage lanes and
						you want the broader service map.
					</p>
				</div>
			</div>
		</div>
	</section>

	<section class="section-xl">
		<div class="shell">
			<div class="section-head">
				<div>
					<p class="eyebrow">Start Here</p>
					<h2 class="section-title">Pick the path that matches the matter.</h2>
					<p class="section-copy">
						The homepage stays focused on three main lanes plus the broader map. Use Practice
						Areas when the matter is real but does not belong in personal injury review, legal
						guidance, or estate planning.
					</p>
				</div>
			</div>

			<div class="route-grid">
				{
					homepageRoutes.map((route) => (
						<a class="route-card" href={route.href}>
							<div>
								<p class="route-card-tag">{route.tag}</p>
								<h3>{route.title}</h3>
								<p>{route.copy}</p>
								<div class="chips">
									{route.links.map((link) => <span class="chip">{link.label}</span>)}
								</div>
							</div>
							<div class="route-card-footer">
								<span class="text-link">{route.footer}</span>
							</div>
						</a>
					))
				}
			</div>
		</div>
	</section>

	<section class="section">
		<div class="shell">
			<div class="highlight-band">
				<div class="band">
					<p class="eyebrow">After Intake</p>
					<h2 class="section-title">Reviewed first. Scheduled second.</h2>
					<p class="lead" style="margin-top: 0;">
						The path is designed to help the office decide what fits before anyone gets pushed
						into the wrong call, the wrong expectation, or the wrong legal lane.
					</p>
					<ol class="hero-process-list">
						{afterIntakeSteps.map((item) => <li>{item}</li>)}
					</ol>
				</div>
				<div class="band">
					<p class="eyebrow">Why This Works</p>
					<h2 class="section-title">A practical path before time gets wasted.</h2>
					<ul class="checklist">
						{practicalPathBullets.map((item) => <li>{item}</li>)}
					</ul>
					<div class="quote" style="margin-top: 18px;">
						Submitting intake does not create an attorney-client relationship. The request is
						reviewed first for fit, conflicts, timing, and next-step availability.
					</div>
				</div>
			</div>
		</div>
	</section>

	<AttorneySpotlight />
	<TestimonialsSection />

	<section class="section">
		<div class="shell">
			<div class="section-head">
				<div>
					<p class="eyebrow">FAQ</p>
					<h2 class="section-title">The questions people usually want answered before they start.</h2>
					<p class="section-copy">
						These are the most common concerns before someone sends a matter in for review or
						decides whether the site fits what they need.
					</p>
				</div>
			</div>

			<div class="faq-list">
				{
					homepageFAQs.map((item) => (
						<div class="faq-item">
							<details>
								<summary>{item.question}</summary>
								<p>{item.answer}</p>
							</details>
						</div>
					))
				}
			</div>
		</div>
	</section>

	<CtaPanel
		title="Ready to send a matter in for review?"
		copy="Use the guided intake to route the matter into the right review lane and get clearer next steps without waiting on a call-back loop."
	/>
</Layout>
