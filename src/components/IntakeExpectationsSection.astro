---
import { intakeExpectations } from '../data/site';
---

<section class="section">
	<div class="shell">
		<div class="section-head">
			<div>
				<p class="eyebrow">What Happens Next</p>
				<h2 class="section-title">What to expect after you submit a request</h2>
			</div>
		</div>

		<div class="grid-4 expectation-grid">
			{
				intakeExpectations.map((item) => (
					<div class="expectation-card">
						<p class="mini-kicker">{item.title}</p>
						<p>{item.copy}</p>
					</div>
				))
			}
		</div>
	</div>
</section>
