---
import { firm } from '../data/site';

interface Props {
	title: string;
	copy: string;
}

const { title, copy } = Astro.props;
---

<section class="section">
	<div class="shell">
		<div class="cta-panel">
			<div>
				<p class="eyebrow">Consultation Path</p>
				<h2 class="section-title">{title}</h2>
				<p>{copy}</p>
			</div>

			<div class="stack-actions">
				<a
					class="button button-primary"
					href="/contact/"
					data-track="generate_lead"
					data-track-label="cta-contact-page"
				>
					Request a Consultation
				</a>
				<a
					class="button button-secondary"
					href={firm.emailHref}
					data-track="generate_lead"
					data-track-label="cta-email"
				>
					Email the Firm
				</a>
			</div>
		</div>
	</div>
</section>
