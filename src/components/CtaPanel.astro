---
import { firm } from '../data/site';

interface Props {
	title: string;
	copy: string;
	href?: string;
}

const { title, copy, href = firm.consultationUrl } = Astro.props;
---

<section class="section">
	<div class="shell">
		<div class="cta-panel">
			<div>
				<p class="eyebrow">Start Intake</p>
				<h2 class="section-title">{title}</h2>
				<p>{copy}</p>
				<p class="mini-copy">Most people finish intake in 2 to 4 minutes. Personal injury matters are screened for fit first. For many non-injury matters that fit, the next step is an email with scheduling instructions for the $100 30-minute consultation.</p>
			</div>

			<div class="stack-actions">
				<a
					class="button button-primary"
					href={href}
					data-track="generate_lead"
					data-track-label="cta-start-intake"
				>
					Start Intake
				</a>
				<a class="button button-ghost" href="/practice-areas/">See Practice Areas</a>
			</div>
		</div>
	</div>
</section>
