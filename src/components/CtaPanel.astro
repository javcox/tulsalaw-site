---
import { firm } from '../data/site';

interface Props {
	title: string;
	copy: string;
	href?: string;
}

const { title, copy, href = firm.consultationUrl } = Astro.props;
---

<section class="section">
	<div class="shell">
		<div class="cta-panel">
			<div>
				<p class="eyebrow">Consultation Path</p>
				<h2 class="section-title">{title}</h2>
				<p>{copy}</p>
				<p class="mini-copy">This usually takes about 2 to 4 minutes and moves the matter into the firm's review queue right away.</p>
			</div>

			<div class="stack-actions">
				<a
					class="button button-primary"
					href={href}
					data-track="generate_lead"
					data-track-label="cta-start-intake"
				>
					Start Intake
				</a>
			</div>
		</div>
	</div>
</section>
