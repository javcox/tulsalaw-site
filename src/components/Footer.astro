---
import { Image } from 'astro:assets';
import headerLogo from '../assets/header-logo-clean.png';
import { featuredServices, firm, getServiceUrl } from '../data/site';
---

<footer class="footer">
	<div class="shell footer-grid">
		<div>
			<div class="brand">
				<span class="brand-emblem" aria-hidden="true">
					<Image
						src={headerLogo}
						alt=""
						widths={[48, 64, 80]}
						sizes="40px"
						loading="lazy"
						format="avif"
					/>
				</span>
				<span class="brand-copy">
					<strong>{firm.name}</strong>
					<span>{firm.legalName}</span>
				</span>
			</div>

			<p class="microcopy" style="margin-top: 18px;">
				{firm.tagline}
			</p>

			<div class="footer-trust-grid">
				<div class="footer-trust-card">
					<strong>Office</strong>
					<p>{firm.fullAddress}</p>
				</div>
				<div class="footer-trust-card">
					<strong>Reply window</strong>
					<p>Most requests are reviewed within 1 business day.</p>
				</div>
				<div class="footer-trust-card">
					<strong>Service area</strong>
					<p>{firm.serviceArea}</p>
				</div>
			</div>

			<div class="stack-actions">
				<a
					class="button button-primary"
					href={firm.consultationUrl}
					data-track="generate_lead"
					data-track-label="footer-start-intake"
				>
					Start Intake
				</a>
			</div>

			<div class="footer-notice">
				<p class="mini-kicker">Attorney advertising and review notice</p>
				<ul class="legal-note-list">
					<li>The information on this site is for general information only.</li>
					<li>Visiting the site, sending email, or submitting intake does not create an attorney-client relationship.</li>
					<li>Representation begins only after conflict review and a confirmed engagement.</li>
				</ul>
				<p class="footer-note">
					If you need to explain something before you start, <a href={firm.emailHref}>email the firm directly</a>.
				</p>
			</div>
		</div>

		<div class="footer-links">
			<div>
				<strong>Most Requested</strong>
				<ul>
					{
						featuredServices.slice(0, 4).map((service) => (
							<li>
								<a href={getServiceUrl(service.slug)}>{service.name}</a>
							</li>
						))
					}
				</ul>
			</div>

			<div>
				<strong>Quick Links</strong>
				<ul>
					<li><a href="/practice-areas/">Practice Areas</a></li>
					<li><a href="/oklahoma-legal-forms/">Simple Legal Services</a></li>
					<li><a href="/about/">About Tracy</a></li>
					<li><a href="/faq/">FAQ</a></li>
					<li><a href="/contact/">Contact</a></li>
					<li><a href={firm.legacyUrl}>Main Firm Site</a></li>
				</ul>
			</div>
		</div>
	</div>
</footer>
