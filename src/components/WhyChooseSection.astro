---
const reasons = [
	{
		title: 'Attorney-led review from Tulsa',
		copy:
			'New matters are reviewed with direct attorney judgment on fit, timing, and next steps rather than being treated like a generic call-center lead.',
	},
	{
		title: 'The lane is clarified before time is wasted',
		copy:
			'Personal injury review, estate planning, legal guidance, family matters, and business documents do not follow the same logic. The site now makes that distinction clearer up front.',
	},
	{
		title: 'You know what happens next',
		copy:
			'Most requests are reviewed within 1 business day. Injury matters are screened for fit first, while non-injury matters that fit usually move next to a paid 30-minute consultation path.',
	},
];
---

<section class="section-xl">
	<div class="shell">
		<div class="section-head">
			<div>
				<p class="eyebrow">Why Tulsa Law</p>
				<h2 class="section-title">A calmer, clearer intake path for Oklahoma legal matters.</h2>
			</div>
		</div>

		<div class="grid-3 why-choose-grid">
			{
				reasons.map((item, index) => (
					<div class="why-card">
						<p class="why-number">{String(index + 1).padStart(2, '0')}</p>
						<h3>{item.title}</h3>
						<p>{item.copy}</p>
					</div>
				))
			}
		</div>
	</div>
</section>
