---
import { Image } from 'astro:assets';
import headerLogo from '../assets/header-logo-clean.png';
import { services } from '../data/site';

const pathname = Astro.url.pathname;
const servicePaths = new Set(services.map((service) => `/${service.slug}/`));
const navLinks = [
	{ href: '/practice-areas/', label: 'Practice Areas' },
	{ href: '/oklahoma-legal-forms/', label: 'Simple Services' },
	{ href: '/about/', label: 'About Tracy' },
	{ href: '/faq/', label: 'FAQ' },
	{ href: '/contact/', label: 'Contact' },
];
---

<header class="site-header">
	<div class="shell header-row">
		<a class="brand" href="/">
			<span class="brand-emblem" aria-hidden="true">
				<Image
					src={headerLogo}
					alt=""
					widths={[48, 64, 80]}
					sizes="40px"
					loading="eager"
					format="avif"
				/>
			</span>
			<span class="brand-copy">
				<strong>Tulsa Law</strong>
				<span class="brand-meta">Super Lawyer&reg; | Tracy Cinocca, J.D.</span>
				<span class="brand-location">Tulsa office | Attorney-led review</span>
			</span>
		</a>

		<nav class="nav" aria-label="Primary">
			{
				navLinks.map((link) => (
					<a
						class={
							link.href === '/practice-areas/'
								? pathname.startsWith(link.href) || servicePaths.has(pathname)
									? 'active'
									: ''
								: pathname.startsWith(link.href)
									? 'active'
									: ''
						}
						href={link.href}
					>
						{link.label}
					</a>
				))
			}
		</nav>

		<div class="header-cta">
			<a
				class="button button-primary"
				href="/start-intake/"
				data-track="generate_lead"
				data-track-label="header-intake"
			>
				Start Intake
			</a>
		</div>
	</div>
</header>
