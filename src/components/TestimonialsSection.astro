---
const reviews = [
	{
		author: 'S.C.',
		context: 'Attorney review',
		quote:
			'She is up-front, honest, and forthcoming in her work, and honesty can sometimes be something you need to hear, not what you want to hear.',
	},
	{
		author: 'N.C.',
		context: 'Legal guidance',
		quote: 'Tracy Cinocca has been extremely helpful with giving legal advice.',
	},
	{
		author: 'J.N.',
		context: 'Legal guidance',
		quote:
			'I have always come away learning something from her that I otherwise would not have known.',
	},
	{
		author: 'D.B.',
		context: 'Pricing and next steps',
		quote: 'I appreciate upfront details on pricing, time frames, and what to expect.',
	},
	{
		author: 'K.M.',
		context: 'Family matter',
		quote: 'Tracy Cinocca helped me navigate my way through a very emotional legal issue.',
	},
	{
		author: 'A.M.',
		context: 'Problem-solving',
		quote: 'She led me to an effective solution to my predicament.',
	},
	{
		author: 'D.B.',
		context: 'Client communication',
		quote: 'Ms. Cinocca was understanding and listened to my needs.',
	},
];
---

<section class="section-xl">
	<div class="shell">
		<div class="section-head">
			<div>
				<p class="eyebrow">Customer Reviews</p>
				<h2 class="section-title">What clients say about clarity, judgment, and follow-through</h2>
			</div>
		</div>

		<div class="review-grid">
			{
				reviews.map((item) => (
					<article class="review-card">
						<p class="review-author">{item.author}</p>
						<p class="review-stars" aria-label="5 out of 5 stars">&starf;&starf;&starf;&starf;&starf;</p>
						<p class="review-context">{item.context}</p>
						<p class="review-quote">"{item.quote}"</p>
					</article>
				))
			}
		</div>
	</div>
</section>
