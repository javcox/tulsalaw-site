---
import type { Service } from '../data/site';
import { getServiceUrl } from '../data/site';

interface Props {
	service: Service;
}

const { service } = Astro.props;
---

<a
	class="service-card"
	href={getServiceUrl(service.slug)}
	data-track="select_content"
	data-track-label={`service-card-${service.slug}`}
>
	<div>
		<div class="category">{service.category}</div>
		<h3>{service.name}</h3>
		<p>{service.summary}</p>
		<p class="mini-copy">Best search fit: {service.searchPhrases[0]}</p>

		<ul class="checklist">
			{service.includes.slice(0, 3).map((item) => <li>{item}</li>)}
		</ul>
	</div>

	<div class="service-card-footer">
		<span class="text-link">Read overview</span>
	</div>
</a>
