---
import type { Service } from '../data/site';
import { getServiceUrl } from '../data/site';

interface Props {
	service: Service;
}

const { service } = Astro.props;
---

<article class="service-card">
	<div>
		<div class="category">{service.category}</div>
		<h3>{service.name}</h3>
		<p>{service.summary}</p>

		<ul class="checklist">
			{service.includes.slice(0, 3).map((item) => <li>{item}</li>)}
		</ul>
	</div>

	<div class="service-card-footer">
		<span class="microcopy">{service.searchPhrases[0]}</span>
		<a class="text-link" href={getServiceUrl(service.slug)}>
			View page
		</a>
	</div>
</article>
